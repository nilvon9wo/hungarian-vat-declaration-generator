{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "VatRates": {
    "SupportedRates": [ 5, 18, 27 ]
  },
  "FileUpload": {
    "MaxFileSizeBytes": 5242880,
    "ProcessingTimeoutSeconds": 30,
    "AllowedContentTypes": [
      "text/csv",
      "application/vnd.ms-excel"
    ],
    "AllowedExtensions": [
      ".csv"
    ]
  },
  "CsvParsing": {
    "MaxRowsToProcess": 10000,
    "MaxInvoiceNumberLength": 100,
    "MaxFieldLength": 500,
    "MaxErrorsToDisplay": 5
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  // ⚠️ SECURITY WARNING - FOR DEMO/CHALLENGE PURPOSES ONLY ⚠️
  // The ApiKey configuration below is for demonstration purposes only.
  // In a production environment:
  // 1. NEVER store credentials, API keys, or secrets in appsettings.json or source control
  // 2. Use proper secret management: Azure Key Vault, AWS Secrets Manager, etc.
  // 3. Use environment variables or secure configuration providers
  // 4. Implement JWT-based authentication with a proper auth server (Azure AD, Auth0, IdentityServer)
  // 5. Rotate keys regularly and use strong, randomly generated values
  "ApiKey": {
    "HeaderName": "X-API-Key",
    "ValidKey": "challenge-demo-key-2024"
  }
}

