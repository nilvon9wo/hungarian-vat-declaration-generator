{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "VatRates": {
    "SupportedRates": [ 5, 18, 27 ]
  },
  "FileUpload": {
    "MaxFileSizeBytes": 10485760,
    "ProcessingTimeoutSeconds": 60,
    "AllowedContentTypes": [
      "text/csv"
    ],
    "AllowedExtensions": [
      ".csv"
    ]
  },
  "CsvParsing": {
    "MaxRowsToProcess": 50000,
    "MaxInvoiceNumberLength": 100,
    "MaxFieldLength": 500,
    "MaxErrorsToDisplay": 3
  },
  "Cors": {
    "AllowedOrigins": [
      "https://hungarian-vat-declaration-generator-web-production.up.railway.app"
    ]
  },
  "Swagger": {
    "EnableInProduction": true
  }
}
