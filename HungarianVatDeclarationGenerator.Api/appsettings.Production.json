{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileUpload": {
    "MaxFileSizeBytes": 10485760,
    "ProcessingTimeoutSeconds": 60,
    "AllowedContentTypes": [
      "text/csv"
    ],
    "AllowedExtensions": [
      ".csv"
    ]
  },
  "CsvParsing": {
    "MaxRowsToProcess": 50000,
    "MaxInvoiceNumberLength": 100,
    "MaxFieldLength": 500,
    "MaxErrorsToDisplay": 3
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.example.com"
    ]
  }
}
